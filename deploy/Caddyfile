{
	auto_https off
}

http://app.example.com {
	# Auth service endpoints: route these directly to the auth service without
	# going through forward_auth. This prevents a redirect loop when the user
	# visits the login page: forward_auth would otherwise intercept the request
	# and redirect to /login again.
	handle /com.auth.forward/* {
		reverse_proxy auth:8080
	}

	# All other requests: check authentication via forward_auth, then proxy to
	# the upstream application.
	handle {
		forward_auth auth:8080 {
			uri /com.auth.forward/auth
			copy_headers X-Auth-User
			# Pass the original request URI so the auth service can redirect back
			# to the requested path after login.
			header_up X-Forwarded-Uri {uri}
		}

		# Demo upstream app. Replace with your real app backend.
		reverse_proxy demo:5678
	}
}

# To generate a JSON config from this Caddyfile, run:
#   caddy adapt --config deploy/Caddyfile --adapter caddyfile > deploy/caddy.json
#
# forward_auth is a Caddyfile directive. Caddy's native JSON config does not
# have a "forward_auth" handler type; caddy adapt compiles the directive into
# the correct reverse_proxy + handle_response form.
#
# For production HTTPS, change http://app.example.com to app.example.com
# (remove the "http://" prefix) and remove "auto_https off" above.
