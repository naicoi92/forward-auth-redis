{
  "apps": {
    "http": {
      "servers": {
        "srv0": {
          "listen": [":80"],
          "routes": [
            {
              "match": [{ "host": ["app.example.com"] }],
              "handle": [
                {
                  "handler": "subroute",
                  "routes": [
                    {
                      "group": "group2",
                      "handle": [
                        {
                          "handler": "subroute",
                          "routes": [
                            {
                              "handle": [
                                {
                                  "handler": "reverse_proxy",
                                  "upstreams": [{ "dial": "auth:8080" }]
                                }
                              ]
                            }
                          ]
                        }
                      ],
                      "match": [{ "path": ["/com.auth.forward/*"] }]
                    },
                    {
                      "group": "group2",
                      "handle": [
                        {
                          "handler": "subroute",
                          "routes": [
                            {
                              "handle": [
                                {
                                  "handle_response": [
                                    {
                                      "match": { "status_code": [2] },
                                      "routes": [
                                        { "handle": [{ "handler": "vars" }] },
                                        {
                                          "handle": [
                                            {
                                              "handler": "headers",
                                              "request": { "delete": ["X-Auth-User"] }
                                            }
                                          ]
                                        },
                                        {
                                          "handle": [
                                            {
                                              "handler": "headers",
                                              "request": {
                                                "set": {
                                                  "X-Auth-User": [
                                                    "{http.reverse_proxy.header.X-Auth-User}"
                                                  ]
                                                }
                                              }
                                            }
                                          ],
                                          "match": [
                                            {
                                              "not": [
                                                {
                                                  "vars": {
                                                    "{http.reverse_proxy.header.X-Auth-User}": [""]
                                                  }
                                                }
                                              ]
                                            }
                                          ]
                                        }
                                      ]
                                    }
                                  ],
                                  "handler": "reverse_proxy",
                                  "headers": {
                                    "request": {
                                      "set": {
                                        "X-Forwarded-Method": ["{http.request.method}"],
                                        "X-Forwarded-Uri": ["{http.request.uri}"]
                                      }
                                    }
                                  },
                                  "rewrite": { "method": "GET", "uri": "/com.auth.forward/auth" },
                                  "upstreams": [{ "dial": "auth:8080" }]
                                },
                                {
                                  "handler": "reverse_proxy",
                                  "upstreams": [{ "dial": "demo:5678" }]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ],
              "terminal": true
            }
          ],
          "automatic_https": { "disable": true }
        }
      }
    }
  }
}
