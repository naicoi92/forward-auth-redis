# Server
LISTEN_ADDR=:8080
BASE_PATH=/com.auth.forward

# Redis
REDIS_MASTER_ADDR=localhost:6379
# Optional: single replica address. Leave empty to read from master.
REDIS_REPLICA_ADDR=localhost:6380
REDIS_PASSWORD=
REDIS_DB=0

# JWT secret (required, >=32 bytes)
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_please_generate_a_strong_secret_with_at_least_32_bytes

# Session / renewal
SESSION_TTL=15m
RENEW_INTERVAL=60s

# Cookie
COOKIE_NAME=fa_token
COOKIE_MAX_AGE=0
# Set false for local HTTP dev (otherwise browser won't send the cookie)
COOKIE_SECURE=false
COOKIE_DOMAIN=

# TOTP
TOTP_ISSUER=forward-auth
TOTP_SKEW=1

# Login protection
MAX_LOGIN_ATTEMPTS=5
LOGIN_WINDOW=5m
OTP_REUSE_TTL=5m

# Replica-lag protection after creating a session (set WAIT_REPLICAS=0 to disable)
SESSION_WAIT_REPLICAS=1
SESSION_WAIT_TIMEOUT=500
